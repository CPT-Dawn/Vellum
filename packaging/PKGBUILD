# Maintainer: CPTDawn <cptdawn@users.noreply.github.com>

pkgname=vellum
pkgver=1.0.0
pkgrel=1
pkgdesc="Native Wayland wallpaper runtime with foreground TUI and background daemon"
arch=('x86_64')
url="https://github.com/CPT-Dawn/Vellum"
license=('MIT')
depends=('wayland' 'lz4')
makedepends=('cargo' 'rust' 'pkgconf' 'wayland-protocols')
source=(
  "Vellum-${pkgver}.tar.gz::${url}/archive/refs/tags/v${pkgver}.tar.gz"
  'vellum.desktop'
  'vellum-daemon.service'
)
sha256sums=(
  'SKIP'
  'aa1a234369f784b31b8b8133f3acad5bb7e0e9b41a32379313ea2f7214ed66fb'
  '409c216c274d0196c77a59a6a873f6eaa24d50e8c7325b6a19d3332f43a25b9c'
)

prepare() {
  cd "${srcdir}/Vellum-${pkgver}"
  cargo fetch --locked
}

build() {
  cd "${srcdir}/Vellum-${pkgver}"
  cargo build --release --locked --frozen --package vellum
}

package() {
  cd "${srcdir}/Vellum-${pkgver}"

  install -Dm755 target/release/vellum "${pkgdir}/usr/bin/vellum"
  install -Dm644 "${srcdir}/vellum.desktop" "${pkgdir}/usr/share/applications/vellum.desktop"
  install -Dm644 "${srcdir}/vellum-daemon.service" "${pkgdir}/usr/lib/systemd/user/vellum-daemon.service"
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
  install -Dm644 README.md "${pkgdir}/usr/share/doc/${pkgname}/README.md"
}